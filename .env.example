# --- Silo Client SDK Configuration ---
# The endpoint URL of your self-hosted Silo server.
SILO_URL=http://localhost:8000

# The administrator/client API key generated during account initialization (silo init).
SILO_API_KEY=silo_key_your_admin_api_key_here

# The UUID of your specific cache bucket.
BUCKET_ID=your-bucket-uuid-here

# The bucket-specific key used to authenticate client cache read/write operations.
BUCKET_KEY=silo_bucket_your_bucket_key_here
